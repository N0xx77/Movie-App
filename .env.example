# Example environment file for Movie-App
# Copy this to .env and fill with your credentials

# TMDB (required) — TMDB v4 Read Access Token
VITE_TMDB_API_KEY=your_tmdb_v4_read_token_here

# Appwrite (required)
VITE_APPWRITE_ENDPOINT=https://appwrite.example.com/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_COLLECTION_ID=your_collection_id_here

# Optional flags
# VITE_SOME_FEATURE_FLAG=true